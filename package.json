{
  "name": "bbps-sdk-react",
  "version": "0.0.2",
  "description": "React Native wrapper SDK for BBPS (Bharat Bill Payment System)",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
