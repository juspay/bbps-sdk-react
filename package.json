  "source": "src/index.ts",
  "files": [
    "src",
    "android",
    "ios",
    "lib",
    "bbps-sdk-react.podspec"
  ],
  "scripts": {
    "typescript": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "build": "bob build"
  },
  "keywords": [
    "react-native",
    "bbps",
    "sdk",
    "payments"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/bbps-sdk-react.git"
  },
  "author": "pawan.singh@juspay.in",
  "homepage": "https://github.com/your-org/bbps-sdk-react",
  "license": "AGPL-3.0",
  "engines": {
    "node": "^20.19.4 || ^22.13.0 || ^24.3.0 || >=25.0.0"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": ">=0.60.0"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.1.3",
    "@react-native-community/cli-platform-android": "^20.1.3",
    "@react-native/metro-config": "^0.85.3",
    "@types/react": "^19.1.1",
    "@types/react-native": "^0.72.0",
    "react": "^19.2.3",
    "react-native": "0.85.3",
    "react-native-builder-bob": "^0.23.2",
    "typescript": "^5.0.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
  }
